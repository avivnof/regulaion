{
  "mindfulness": [
    {
      "type": "text",
      "start": "00:07",
      "end": "00:10",
      "text": "נשב בצורה נוחה"
    },
    {
      "type": "text",
      "start": "00:10",
      "end": "00:20",
      "text": "עצמו את העיניים אם נוח לכם"
    },
    {
      "type": "text",
      "start": "00:13",
      "end": "00:17",
      "text": "ניתן לעצום את העיניים או להתבונן בנקודה"
    },
    {
      "type": "text",
      "start": "00:21",
      "end": "00:30",
      "text": "נשים לב שהתנוחה בכיסא נוחה לנו"
    },
    {
      "type": "text",
      "start": "00:31",
      "end": "00:38",
      "text": "נשים לב לנשימות"
    },
    {
      "type": "text",
      "start": "00:39",
      "end": "00:43",
      "text": "הנשימות הן עוגן להווה"
    },
    {
      "type": "text",
      "start": "00:45",
      "end": "00:52",
      "text": "נקשיב לנשימות"
    },
    {
      "type": "text",
      "start": "00:54",
      "end": "00:58",
      "text": "נתבונן בנשימות בלי לנסות לשנותן"
    },
    {
      "type": "text",
      "start": "00:59",
      "end": "01:18",
      "text": "נתבונן בנשימות בלי שיפוטיות"
    },
    {
      "type": "text",
      "start": "01:20",
      "end": "01:26",
      "text": "נשים לב לתחושות הגופניות"
    },
    {
      "type": "text",
      "start": "01:26",
      "end": "01:37",
      "text": "נשים לב למגע של הגוף בכסא"
    },
    {
      "type": "text",
      "start": "01:39",
      "end": "01:43",
      "text": "לא שופטים"
    },
    {
      "type": "text",
      "start": "01:42",
      "end": "01:58",
      "text": "מתבוננים"
    },
    {
      "type": "text",
      "start": "02:16",
      "end": "02:21",
      "text": "נשים לב לתחושות הגופניות"
    },
    {
      "type": "text",
      "start": "02:22",
      "end": "02:29",
      "text": "תמיד אפשר לחזור לעוגן הנשימות"
    },
    {
      "type": "text",
      "start": "02:29",
      "end": "03:00",
      "text": "נתבונן בתחושות הגופניות"
    },
    {
      "type": "text",
      "start": "02:59",
      "end": "03:13",
      "text": "נשים לב לנשימות"
    },
    {
      "type": "text",
      "start": "03:22",
      "end": "03:31",
      "text": "הנשימות תמיד בהווה והן עוגן"
    },
    {
      "type": "text",
      "start": "03:37",
      "end": "04:06",
      "text": "נתבונן בנשימות"
    },
    {
      "type": "text",
      "start": "04:11",
      "end": "04:37",
      "text": "המחשבות - נתבונן"
    },
    {
      "type": "text",
      "start": "04:37",
      "end": "04:47",
      "text": "המחשבות הן כמו בולי עץ החולפים בנהר זורם"
    },
    {
      "type": "text",
      "start": "04:47",
      "end": "05:05",
      "text": "נקבל את המחשבות כמו שהן"
    },
    {
      "type": "text",
      "start": "05:06",
      "end": "05:32",
      "text": "תמיד אפשר לחזור לעוגן הנשימות כדי להיות בהווה"
    },
    {
      "type": "text",
      "start": "05:33",
      "end": "06:15",
      "text": "נתבונן במחשבות כעת"
    },
    {
      "type": "text",
      "start": "06:18",
      "end": "06:30",
      "text": "נעבור לשים לב לרגשות"
    },
    {
      "type": "text",
      "start": "06:45",
      "end": "06:54",
      "text": "כל סוגי הרגשות מקובלים עלינו והרגשות בשינוי"
    },
    {
      "type": "text",
      "start": "06:54",
      "end": "07:05",
      "text": "מתבוננים ברגשות ואפשר לתת שמות לרגשות"
    },
    {
      "type": "text",
      "start": "07:07",
      "end": "07:23",
      "text": "תמיד אפשר לחזור לנשימות כעוגן"
    },
    {
      "type": "text",
      "start": "07:23",
      "end": "08:11",
      "text": "נתבונן כעת ברגשות ללא שיפוטיות"
    },
    {
      "type": "text",
      "start": "08:12",
      "end": "08:27",
      "text": "נשים לב שוב לנשימות כעוגן לכאן ולעכשיו"
    },
    {
      "type": "text",
      "start": "08:27",
      "end": "08:39",
      "text": "נשים לב לחוויה הכללית שלנו"
    },
    {
      "type": "text",
      "start": "08:40",
      "end": "08:53",
      "text": "לא מנסים לשנות דבר - רק מתבוננים"
    },
    {
      "type": "text",
      "start": "08:54",
      "end": "09:08",
      "text": "תמיד אפשר לחזור לנשימות כעוגן"
    },
    {
      "type": "text",
      "start": "09:08",
      "end": "09:52",
      "text": "נתבונן עכשיו בתחושות הכלליות - בגוף, במחשבות, ברגשות"
    },
    {
      "type": "text",
      "start": "09:54",
      "end": "10:04",
      "text": "נחזור לשים לב לנשימות"
    },
    {
      "type": "text",
      "start": "10:05",
      "end": "10:13",
      "text": "נתמקד במה שמתרחש סביבנו"
    },
    {
      "type": "text",
      "start": "10:13",
      "end": "10:38",
      "text": "מתבוננים במה שקורה בסביבה בלי שיפוטיות"
    },
    {
      "type": "text",
      "start": "10:42",
      "end": "10:55",
      "text": "תמיד אפשר לחזור להתמקד בנשימות כעוגן"
    },
    {
      "type": "text",
      "start": "10:59",
      "end": "11:41",
      "text": "נשים לב ונתבונן במה שמתרחש סביבנו"
    },
    {
      "type": "text",
      "start": "11:42",
      "end": "11:57",
      "text": "נשים לב לנשימות שוב"
    },
    {
      "type": "text",
      "start": "11:59",
      "end": "12:11",
      "text": "סיום התרגיל מתקרב"
    },
    {
      "type": "text",
      "start": "12:12",
      "end": "12:24",
      "text": "נדמיין את עצמנו יושבים בחדר"
    },
    {
      "type": "text",
      "start": "12:26",
      "end": "12:33",
      "text": "נזיז קלות את האצבעות ואת הראש בעדינות"
    },
    {
      "type": "text",
      "start": "12:33",
      "end": "12:40",
      "text": "נפקח את העיניים"
    },
    {
      "type": "text",
      "start": "12:43",
      "end": "13:00",
      "text": "תודה שתרגלתם ותזכרו שחשוב להמשיך להיות בעמדת קשיבות"
    }
  ],
